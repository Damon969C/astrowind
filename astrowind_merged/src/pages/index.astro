---
import Layout from '~/layouts/PageLayout.astro';
import PageHero from '~/components/ops/PageHero.astro';
import CategoryGrid from '~/components/ops/CategoryGrid.astro';
import { contentGroups, contentPages } from '~/data/content';
import { downloadCategories } from '~/data/downloads';

const metadata = {
  title: '系统配置与下载中心',
  description: 'Debian、PVE、VyOS、Windows 命令配置与脚本工具下载。',
  ignoreTitleTemplate: true,
};

const groupCards = [
  {
    title: 'Debian',
    summary: 'Linux 服务部署、容器、证书、网络与常用运维命令。',
    href: '/debian/linux-kernel-build',
    meta: `${contentGroups.debian.length} 个页面`,
  },
  {
    title: 'PVE',
    summary: 'Proxmox VE 配置、磁盘、ZFS、ASPM 与虚拟机管理。',
    href: '/pve/config',
    meta: `${contentGroups.pve.length} 个页面`,
  },
  {
    title: 'VyOS配置',
    summary: 'VyOS 安装、接口、LAN/WAN、DNS、防火墙与路由配置。',
    href: '/vyos/install',
    meta: `${contentGroups.vyos.length} 个页面`,
  },
  {
    title: 'Windows',
    summary: 'Windows 校验、激活、ADB 与网络排查命令。',
    href: '/windows/md5-win2022',
    meta: `${contentGroups.windows.length} 个页面`,
  },
  {
    title: '下载',
    summary: 'Debian 脚本、Windows 工具、注册表文件和图片素材。',
    href: '/downloads',
    meta: `${downloadCategories.length} 个分类`,
  },
];
---

<Layout metadata={metadata}>
  <PageHero
    eyebrow="Static Ops Library"
    title="系统配置与下载中心"
    summary="把常用命令、系统配置、脚本工具和下载资源整理为一个可静态托管的 Astrowind 站点。命令可单行复制，配置与脚本可整段复制。"
  />

  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6">
    <CategoryGrid cards={groupCards} />

    <div
      class="mt-10 grid gap-4 rounded-md border border-gray-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900 md:grid-cols-3"
    >
      <div>
        <p class="text-3xl font-bold text-gray-900 dark:text-white">{contentPages.length}</p>
        <p class="mt-1 text-sm font-bold text-muted dark:text-slate-400">配置与命令页面</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900 dark:text-white">
          {downloadCategories.reduce((sum, category) => sum + category.items.length, 0)}
        </p>
        <p class="mt-1 text-sm font-bold text-muted dark:text-slate-400">下载文件</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900 dark:text-white">Astro</p>
        <p class="mt-1 text-sm font-bold text-muted dark:text-slate-400">静态构建</p>
      </div>
    </div>
  </section>
</Layout>
