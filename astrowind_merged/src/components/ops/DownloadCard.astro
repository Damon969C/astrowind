---
import { formatBytes, type DownloadItem } from '~/data/downloads';

interface Props {
  item: DownloadItem;
}

const { item } = Astro.props;
const href = item.path
  .split('/')
  .map((part, index) => (index === 0 ? part : encodeURIComponent(part)))
  .join('/');
---

<article class="rounded-md border border-gray-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900">
  {
    item.isImage && (
      <img
        class="mb-4 aspect-video w-full rounded-md border border-gray-200 object-cover dark:border-slate-800"
        src={href}
        alt={item.filename}
        loading="lazy"
      />
    )
  }
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <h2 class="break-words text-lg font-bold text-gray-900 dark:text-white">{item.filename}</h2>
      <p class="mt-2 text-sm text-muted dark:text-slate-400">{item.kind} · {formatBytes(item.size)}</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          item.tags.map((tag) => (
            <span class="rounded-full bg-primary/10 px-2.5 py-1 text-xs font-bold text-primary">{tag}</span>
          ))
        }
      </div>
    </div>
    <a
      class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-bold text-white transition hover:bg-primary/90"
      href={href}
      download={item.filename}
    >
      下载
    </a>
  </div>
  <div
    class="mt-4 rounded-md bg-slate-100 p-3 font-mono text-xs leading-6 text-slate-700 break-all dark:bg-slate-950 dark:text-slate-300"
  >
    SHA-256 {item.sha256}
  </div>
</article>
