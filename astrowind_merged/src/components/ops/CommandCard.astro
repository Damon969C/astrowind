---
import CopyCode from './CopyCode.astro';
import type { ContentItem } from '~/data/content';

interface Props {
  item: ContentItem;
  id?: string;
}

const { item, id } = Astro.props;
const filterText = `${item.title} ${item.fields.map((field) => field.value).join(' ')}`;
---

<article
  id={id}
  class="filter-item scroll-mt-24 border-b border-gray-200 py-8 last:border-b-0 dark:border-slate-800"
  data-filter-text={filterText}
>
  <header class="mb-5">
    <h2 class="text-2xl font-bold leading-snug text-gray-900 dark:text-white">{item.title}</h2>
  </header>

  <div class="space-y-5">
    {
      item.fields.map((field) =>
        field.type === 'code' ? (
          <CopyCode code={field.value} copyMode={field.copyMode} />
        ) : (
          <p class="whitespace-pre-line text-base leading-8 text-slate-700 dark:text-slate-300">{field.value}</p>
        )
      )
    }
  </div>
</article>
