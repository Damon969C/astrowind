---
import { getPermalink } from '~/utils/permalinks';

interface Card {
  title: string;
  summary?: string;
  href: string;
  meta?: string;
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {
    cards.map((card) => (
      <a
        class="group rounded-md border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
        href={getPermalink(card.href)}
      >
        <h2 class="text-xl font-bold text-gray-900 group-hover:text-primary dark:text-white">{card.title}</h2>
        {card.summary && <p class="mt-3 text-sm leading-7 text-muted dark:text-slate-400">{card.summary}</p>}
        {card.meta && <p class="mt-4 text-xs font-bold uppercase text-primary">{card.meta}</p>}
      </a>
    ))
  }
</div>
