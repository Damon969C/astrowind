---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
}

const { title, summary } = Astro.props;
---

<section class="relative mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-14">
  <div class="max-w-4xl">
    <h1 class="text-4xl font-bold leading-tight text-gray-900 dark:text-white md:text-5xl">{title}</h1>
    {summary && <p class="mt-5 text-lg leading-8 text-muted dark:text-slate-300">{summary}</p>}
  </div>
</section>
